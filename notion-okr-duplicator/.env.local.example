NOTION_TOKEN=YOUR_NOTION_TOKEN_HERE
NOTION_BASE_URL=https://api.notion.com

# Use one of the following:
NOTION_PAGE_ID=
NOTION_DATABASE_ID=
NOTION_DATA_SOURCE_ID=

# If you use NOTION_PAGE_ID, the page itself must also be shared with the integration.
# If only the database is shared, prefer NOTION_DATABASE_ID or NOTION_DATA_SOURCE_ID.

# Optional when the page contains multiple child databases.
NOTION_CHILD_DATABASE_TITLE=

# Optional when the database contains multiple data sources.
NOTION_DATA_SOURCE_NAME=

NOTION_PERIOD_PROPERTY=対象期間
NOTION_OBJECT_PROPERTY=Objects
NOTION_KEY_PROPERTY=Keys

# Safety defaults:
NOTION_EXECUTE=false
NOTION_LIMIT=
NOTION_TIMEOUT_SECONDS=30
